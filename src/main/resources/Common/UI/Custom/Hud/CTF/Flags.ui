Group #CtfFlagsHud {
  Anchor: (Top: 18, Right: 18, Width: 352, Height: 224);
  LayoutMode: Top;

  Group #FlagsPanel {
    Background: (TexturePath: "../RealmRulerTheme/RealmCardAction.png", Border: 18);
    Anchor: (Width: 352, Height: 224);
    Padding: (Horizontal: 18, Vertical: 14);
    LayoutMode: Top;

    Group #FlagsPlaque {
      Anchor: (Width: 132, Height: 30);
      LayoutMode: Center;
      Background: (TexturePath: "../RealmRulerTheme/RealmMiniPlaque.png", Border: 12);

      Label #FlagsTitle {
        Anchor: (Width: 86, Height: 20);
        Style: (FontSize: 15, Alignment: Center);
        Text: "Flags";
      }
    }

    Group #FlagsAccent {
      Anchor: (Top: 12, Width: 316, Height: 4);
      Background: (TexturePath: "../RealmRulerTheme/RealmDivider.png", Border: 4);
    }

    Group #RedRow {
      Anchor: (Top: 14, Width: 316, Height: 34);
      LayoutMode: Left;
      Background: (TexturePath: "../RealmRulerTheme/RealmRow.png", Border: 8);

      Label #RedFlagStatus {
        Anchor: (Width: 270, Height: 34);
        Style: (FontSize: 15, Alignment: Start);
        Text: "";
      }

      Group #RedFlagIcon {
        Anchor: (Left: 12, Width: 22, Height: 22);
        Background: #d32f2f(1.0);
      }
    }

    Group #BlueRow {
      Anchor: (Top: 10, Width: 316, Height: 34);
      LayoutMode: Left;
      Background: (TexturePath: "../RealmRulerTheme/RealmRow.png", Border: 8);

      Label #BlueFlagStatus {
        Anchor: (Width: 270, Height: 34);
        Style: (FontSize: 15, Alignment: Start);
        Text: "";
      }

      Group #BlueFlagIcon {
        Anchor: (Left: 12, Width: 22, Height: 22);
        Background: #1976d2(1.0);
      }
    }

    Group #YellowRow {
      Anchor: (Top: 10, Width: 316, Height: 34);
      LayoutMode: Left;
      Background: (TexturePath: "../RealmRulerTheme/RealmRow.png", Border: 8);

      Label #YellowFlagStatus {
        Anchor: (Width: 270, Height: 34);
        Style: (FontSize: 15, Alignment: Start);
        Text: "";
      }

      Group #YellowFlagIcon {
        Anchor: (Left: 12, Width: 22, Height: 22);
        Background: #fbc02d(1.0);
      }
    }

    Group #WhiteRow {
      Anchor: (Top: 10, Width: 316, Height: 34);
      LayoutMode: Left;
      Background: (TexturePath: "../RealmRulerTheme/RealmRow.png", Border: 8);

      Label #WhiteFlagStatus {
        Anchor: (Width: 270, Height: 34);
        Style: (FontSize: 15, Alignment: Start);
        Text: "";
      }

      Group #WhiteFlagIcon {
        Anchor: (Left: 12, Width: 22, Height: 22);
        Background: #eeeeee(1.0);
      }
    }
  }
}
