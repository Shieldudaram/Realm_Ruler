Group #RealmRulerCtfStandsPage {
  Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
  LayoutMode: Center;

  Group #Backdrop {
    Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
    Background: #02050b(0.74);
  }

  Group #Window {
    Anchor: (Width: 948, Height: 830);
    LayoutMode: Center;
    Padding: (Horizontal: 14, Vertical: 14);
    Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmFrame.png", Border: 24);

    Group #Panel {
      Anchor: (Width: 920, Height: 802);
      LayoutMode: Top;
      Padding: (Horizontal: 20, Vertical: 20);
      Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmInset.png", Border: 18);

      Group #HeaderBand {
        Anchor: (Width: 880, Height: 180);
        LayoutMode: Top;
        Padding: (Horizontal: 18, Vertical: 14);
        Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmInset.png", Border: 16);

        Group #HeaderTopRow {
          Anchor: (Width: 844, Height: 40);
          LayoutMode: Left;

          Group #BackAction {
            Anchor: (Width: 138, Height: 34);
            LayoutMode: Center;

            TextButton #BackButton {
              Anchor: (Width: 138, Height: 34);
              Padding: (Horizontal: 16, Bottom: 1);
              Text: "Back";
              Style: @RealmStandsBackButtonStyle;
            }
          }

          Group #HeaderTopSpacer {
            Anchor: (Left: 10, Width: 696, Height: 40);
          }

        }

        Group #HeaderPlaque {
          Anchor: (Top: 12, Width: 760, Height: 60);
          LayoutMode: Top;
          Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmTitlePlaque.png", Border: 18);

          Group #TitleLane {
            Anchor: (Top: 5, Width: 620, Height: 36);
            LayoutMode: Top;

            Group #TitleTextBand {
              Anchor: (Top: 2, Width: 600, Height: 32);
              LayoutMode: Center;

              Label #TitleLabel {
                Anchor: (Width: 600, Height: 32);
                Style: (FontSize: 30, Alignment: Center, RenderBold: true, TextColor: #f7f1e3, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 24);
                Text: "Stand Registry";
              }
            }
          }
        }

        Group #PointsBadgeRow {
          Anchor: (Top: 4, Width: 760, Height: 24);
          LayoutMode: Center;

          Group #PointsSpacer {
            Anchor: (Width: 244, Height: 24);
          }
        }

        Group #SubtitleRow {
          Anchor: (Top: 8, Width: 720, Height: 22);
          LayoutMode: Center;

          Group #SubtitleLane {
            Anchor: (Width: 720, Height: 18);
            LayoutMode: Top;

            Group #SubtitleTextBand {
              Anchor: (Top: 1, Width: 708, Height: 16);
              LayoutMode: Center;

              Label #SubtitleLabel {
                Anchor: (Width: 708, Height: 16);
                Style: (FontSize: 15, Alignment: Center, TextColor: #e0ebf4(0.94), ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 13);
                Text: "Review stand locations by team and keep actions inside one registry.";
              }
            }
          }
        }
      }

      Group #StatusBanner {
        Anchor: (Top: 14, Width: 880, Height: 40);
        LayoutMode: Center;
        Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmStatusRibbon.png", Border: 14);

        Label #StatusLabel {
          Anchor: (Width: 788, Height: 20);
          Style: (FontSize: 15, Alignment: Center);
          Text: "";
        }
      }

      Group #TeamCard {
        Anchor: (Top: 16, Width: 880, Height: 100);
        LayoutMode: Top;
        Padding: (Horizontal: 18, Vertical: 14);
        Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmCardAction.png", Border: 18);

        Group #TeamPlaque {
          Anchor: (Width: 170, Height: 30);
          LayoutMode: Center;
          Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmMiniPlaque.png", Border: 12);

          Label #TeamTitle {
            Anchor: (Width: 104, Height: 20);
            Style: (FontSize: 16, Alignment: Center);
            Text: "Team";
          }
        }

        Group #TeamRow {
          Anchor: (Top: 14, Width: 844, Height: 44);
          LayoutMode: Left;

          Group #SelectedTeamPlate {
            Anchor: (Width: 92, Height: 40);
            LayoutMode: Center;
            Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmMiniPlaque.png", Border: 12);

            Label #SelectedTeamValue {
              Anchor: (Width: 54, Height: 18);
              Style: (FontSize: 13, Alignment: Center, TextColor: #d4dfeb(0.86));
              Text: "Team";
            }
          }

          Group #TeamRedAction {
            Anchor: (Left: 8, Width: 138, Height: 44);
            LayoutMode: Center;

            Group #TeamRedSelectedAccent {
              Anchor: (Top: 36, Width: 96, Height: 4);
              Background: #4fc5ff(0.98);
              Visible: false;
            }

            TextButton #TeamRedButton {
              Anchor: (Width: 138, Height: 44);
              Padding: (Horizontal: 16, Bottom: 1);
              Text: "Red";
              Style: @RealmStandsRedButtonStyle;
            }
          }

          Group #TeamBlueAction {
            Anchor: (Left: 8, Width: 138, Height: 44);
            LayoutMode: Center;

            Group #TeamBlueSelectedAccent {
              Anchor: (Top: 36, Width: 96, Height: 4);
              Background: #4fc5ff(0.98);
              Visible: false;
            }

            TextButton #TeamBlueButton {
              Anchor: (Width: 138, Height: 44);
              Padding: (Horizontal: 16, Bottom: 1);
              Text: "Blue";
              Style: @RealmStandsBlueButtonStyle;
            }
          }

          Group #TeamYellowAction {
            Anchor: (Left: 8, Width: 138, Height: 44);
            LayoutMode: Center;

            Group #TeamYellowSelectedAccent {
              Anchor: (Top: 36, Width: 96, Height: 4);
              Background: #4fc5ff(0.98);
              Visible: false;
            }

            TextButton #TeamYellowButton {
              Anchor: (Width: 138, Height: 44);
              Padding: (Horizontal: 16, Bottom: 1);
              Text: "Yellow";
              Style: @RealmStandsYellowButtonStyle;
            }
          }

          Group #TeamWhiteAction {
            Anchor: (Left: 8, Width: 138, Height: 44);
            LayoutMode: Center;

            Group #TeamWhiteSelectedAccent {
              Anchor: (Top: 36, Width: 96, Height: 4);
              Background: #4fc5ff(0.98);
              Visible: false;
            }

            TextButton #TeamWhiteButton {
              Anchor: (Width: 138, Height: 44);
              Padding: (Horizontal: 16, Bottom: 1);
              Text: "White";
              Style: @RealmStandsWhiteButtonStyle;
            }
          }
        }
      }

      Group #ListCard {
        Anchor: (Top: 18, Width: 880, Height: 456);
        LayoutMode: Top;
        Padding: (Horizontal: 18, Vertical: 16);
        Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmCardInfo.png", Border: 18);

        Group #ListPlaque {
          Anchor: (Width: 224, Height: 34);
          LayoutMode: Center;
          Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmMiniPlaque.png", Border: 12);

          Label #ListTitle {
            Anchor: (Width: 166, Height: 22);
            Style: (FontSize: 16, Alignment: Center);
            Text: "Registered Stands";
          }
        }

        Group #Row0 {
          Anchor: (Top: 12, Width: 844, Height: 40);
          LayoutMode: Left;
          Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmRow.png", Border: 8);

          Group #Row0SelectedAccent {
            Anchor: (Width: 12, Height: 40);
            Background: #4fc5ff(0.98);
            Visible: false;
          }

          Label #Row0Label {
            Anchor: (Left: 14, Width: 608, Height: 40);
            Style: (FontSize: 15, Alignment: Start);
            Text: "Stand row";
          }

          Group #Row0Action {
            Anchor: (Left: 12, Width: 210, Height: 40);
            LayoutMode: Center;

            TextButton #Row0Button {
              Anchor: (Width: 210, Height: 40);
              Padding: (Horizontal: 16, Bottom: 1);
              Text: "Select";
              Style: @RealmStandsCompactSubtleButtonStyle;
            }
          }
        }

        Group #Row1 {
          Anchor: (Top: 8, Width: 844, Height: 40);
