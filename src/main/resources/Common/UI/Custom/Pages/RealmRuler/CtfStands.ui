          Group #PrimaryAction {
            Anchor: (Left: 10, Width: 192, Height: 38);
            LayoutMode: Center;

            TextButton #PrimaryButton {
              Anchor: (Width: 192, Height: 38);
              Padding: (Horizontal: 12, Bottom: 1);
              Text: "Set Primary";
              Style: @RealmStandsCompactSubtleButtonStyle;
            }
          }
        }
      }

      Group #PageFooter {
        Anchor: (Top: 16, Width: 880, Height: 48);
        LayoutMode: Center;

        Group #FooterPill {
          Anchor: (Width: 446, Height: 46);
          LayoutMode: Center;
          Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmMainFooterPill.png", Border: 16);

          Label #CloseHint {
            Anchor: (Width: 278, Height: 24);
            Style: (FontSize: 18, Alignment: Center, RenderBold: true, TextColor: #e7eff5);
            Text: "Press Esc to close";
          }
        }
      }
    }
  }
}
