@RealmStandsButtonLabelStyle = LabelStyle(
  FontSize: 15,
  TextColor: #dbe7f0,
  RenderBold: true,
  HorizontalAlignment: Center,
  VerticalAlignment: Center,
  ShrinkTextToFit: true,
  MinShrinkTextToFitFontSize: 11,
  LetterSpacing: 1
);

@RealmStandsButtonHoveredLabelStyle = LabelStyle(
  ...@RealmStandsButtonLabelStyle,
  TextColor: #f3fbff
);

@RealmStandsButtonPressedLabelStyle = LabelStyle(
  ...@RealmStandsButtonLabelStyle,
  TextColor: #c9d5de
);

@RealmStandsButtonDisabledLabelStyle = LabelStyle(
  ...@RealmStandsButtonLabelStyle,
  TextColor: #9ea9b3
);

@RealmStandsBackButtonLabelStyle = LabelStyle(
  ...@RealmStandsButtonLabelStyle,
  FontSize: 14,
  MinShrinkTextToFitFontSize: 10
);

@RealmStandsBackButtonHoveredLabelStyle = LabelStyle(
  ...@RealmStandsBackButtonLabelStyle,
  TextColor: #f3fbff
);

@RealmStandsBackButtonPressedLabelStyle = LabelStyle(
  ...@RealmStandsBackButtonLabelStyle,
  TextColor: #c9d5de
);

@RealmStandsBackButtonDisabledLabelStyle = LabelStyle(
  ...@RealmStandsBackButtonLabelStyle,
  TextColor: #9ea9b3
);

@RealmStandsCompactButtonLabelStyle = LabelStyle(
  FontSize: 13,
  TextColor: #dbe7f0,
  RenderBold: true,
  HorizontalAlignment: Center,
  VerticalAlignment: Center,
  ShrinkTextToFit: true,
  MinShrinkTextToFitFontSize: 10,
  LetterSpacing: 0
);

@RealmStandsCompactButtonHoveredLabelStyle = LabelStyle(
  ...@RealmStandsCompactButtonLabelStyle,
  TextColor: #f3fbff
);

@RealmStandsCompactButtonPressedLabelStyle = LabelStyle(
  ...@RealmStandsCompactButtonLabelStyle,
  TextColor: #c9d5de
);

@RealmStandsCompactButtonDisabledLabelStyle = LabelStyle(
  ...@RealmStandsCompactButtonLabelStyle,
  TextColor: #9ea9b3
);

@RealmStandsBackButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle.png", Border: 12), LabelStyle: @RealmStandsBackButtonLabelStyle),
  Hovered: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle_Hovered.png", Border: 12), LabelStyle: @RealmStandsBackButtonHoveredLabelStyle),
  Pressed: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle_Pressed.png", Border: 12), LabelStyle: @RealmStandsBackButtonPressedLabelStyle),
  Disabled: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle.png", Border: 12, Color: #ffffff(0.58)), LabelStyle: @RealmStandsBackButtonDisabledLabelStyle)
);

@RealmStandsGoldButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButton.png", Border: 12), LabelStyle: @RealmStandsButtonLabelStyle),
  Hovered: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButton_Hovered.png", Border: 12), LabelStyle: @RealmStandsButtonHoveredLabelStyle),
