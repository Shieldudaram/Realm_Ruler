@RealmMatchButtonLabelStyle = LabelStyle(
  FontSize: 15,
  TextColor: #dbe7f0,
  RenderBold: true,
  HorizontalAlignment: Center,
  VerticalAlignment: Center,
  ShrinkTextToFit: true,
  MinShrinkTextToFitFontSize: 11,
  LetterSpacing: 1
);

@RealmMatchButtonHoveredLabelStyle = LabelStyle(
  ...@RealmMatchButtonLabelStyle,
  TextColor: #f3fbff
);

@RealmMatchButtonPressedLabelStyle = LabelStyle(
  ...@RealmMatchButtonLabelStyle,
  TextColor: #c9d5de
);

@RealmMatchButtonDisabledLabelStyle = LabelStyle(
  ...@RealmMatchButtonLabelStyle,
  TextColor: #9ea9b3
);

@RealmMatchHomeButtonLabelStyle = LabelStyle(
  ...@RealmMatchButtonLabelStyle,
  FontSize: 14,
  MinShrinkTextToFitFontSize: 10
);

@RealmMatchHomeButtonHoveredLabelStyle = LabelStyle(
  ...@RealmMatchHomeButtonLabelStyle,
  TextColor: #f3fbff
);

@RealmMatchHomeButtonPressedLabelStyle = LabelStyle(
  ...@RealmMatchHomeButtonLabelStyle,
  TextColor: #c9d5de
);

@RealmMatchHomeButtonDisabledLabelStyle = LabelStyle(
  ...@RealmMatchHomeButtonLabelStyle,
  TextColor: #9ea9b3
);

@RealmMatchHomeButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle.png", Border: 12), LabelStyle: @RealmMatchHomeButtonLabelStyle),
  Hovered: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle_Hovered.png", Border: 12), LabelStyle: @RealmMatchHomeButtonHoveredLabelStyle),
  Pressed: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle_Pressed.png", Border: 12), LabelStyle: @RealmMatchHomeButtonPressedLabelStyle),
  Disabled: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle.png", Border: 12, Color: #ffffff(0.58)), LabelStyle: @RealmMatchHomeButtonDisabledLabelStyle)
);

@RealmMatchGoldButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButton.png", Border: 12), LabelStyle: @RealmMatchButtonLabelStyle),
  Hovered: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButton_Hovered.png", Border: 12), LabelStyle: @RealmMatchButtonHoveredLabelStyle),
  Pressed: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButton_Pressed.png", Border: 12), LabelStyle: @RealmMatchButtonPressedLabelStyle),
  Disabled: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButton.png", Border: 12, Color: #ffffff(0.58)), LabelStyle: @RealmMatchButtonDisabledLabelStyle)
);

@RealmMatchDangerButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonDanger.png", Border: 12), LabelStyle: @RealmMatchButtonLabelStyle),
  Hovered: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonDanger_Hovered.png", Border: 12), LabelStyle: @RealmMatchButtonHoveredLabelStyle),
  Pressed: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonDanger_Pressed.png", Border: 12), LabelStyle: @RealmMatchButtonPressedLabelStyle),
  Disabled: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonDanger.png", Border: 12, Color: #ffffff(0.58)), LabelStyle: @RealmMatchButtonDisabledLabelStyle)
);

@RealmMatchSubtleButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle.png", Border: 12), LabelStyle: @RealmMatchButtonLabelStyle),
  Hovered: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle_Hovered.png", Border: 12), LabelStyle: @RealmMatchButtonHoveredLabelStyle),
  Pressed: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle_Pressed.png", Border: 12), LabelStyle: @RealmMatchButtonPressedLabelStyle),
  Disabled: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle.png", Border: 12, Color: #ffffff(0.58)), LabelStyle: @RealmMatchButtonDisabledLabelStyle)
);

@RealmMatchStepperButtonLabelStyle = LabelStyle(
  FontSize: 34,
  TextColor: #e7f2f8,
  RenderBold: true,
  HorizontalAlignment: Center,
  VerticalAlignment: Center,
  LetterSpacing: 0
);

@RealmMatchStepperHoveredLabelStyle = LabelStyle(
  ...@RealmMatchStepperButtonLabelStyle,
  TextColor: #ffffff
);

@RealmMatchStepperPressedLabelStyle = LabelStyle(
  ...@RealmMatchStepperButtonLabelStyle,
  TextColor: #d6dde4
);

@RealmMatchStepperButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle.png", Border: 12), LabelStyle: @RealmMatchStepperButtonLabelStyle),
  Hovered: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle_Hovered.png", Border: 12), LabelStyle: @RealmMatchStepperHoveredLabelStyle),
  Pressed: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle_Pressed.png", Border: 12), LabelStyle: @RealmMatchStepperPressedLabelStyle),
  Disabled: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle.png", Border: 12, Color: #ffffff(0.58)), LabelStyle: @RealmMatchStepperPressedLabelStyle)
);

Group #RealmRulerCtfMatchPage {
  Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
  LayoutMode: Center;

  Group #Backdrop {
    Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
    Background: #02050b(0.74);
  }

  Group #Window {
    Anchor: (Width: 944, Height: 868);
    LayoutMode: Center;
    Padding: (Horizontal: 14, Vertical: 14);
    Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmFrame.png", Border: 24);

    Group #Panel {
      Anchor: (Width: 916, Height: 840);
      LayoutMode: Top;
      Padding: (Horizontal: 20, Vertical: 20);
      Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmInset.png", Border: 18);

      Group #HeaderBand {
        Anchor: (Width: 876, Height: 156);
        LayoutMode: Top;
        Padding: (Horizontal: 18, Vertical: 14);
        Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmInset.png", Border: 16);

        Group #HeaderTopRow {
          Anchor: (Width: 840, Height: 40);
          LayoutMode: Left;

          Group #HomeAction {
            Anchor: (Width: 138, Height: 34);
            LayoutMode: Center;

            TextButton #HomeButton {
              Anchor: (Width: 138, Height: 34);
              Padding: (Horizontal: 16, Bottom: 1);
              Text: "Home";
              Style: @RealmMatchHomeButtonStyle;
            }
          }

          Group #HeaderTopSpacer {
            Anchor: (Left: 10, Width: 458, Height: 40);
          }

        Group #PointsBadge {
          Anchor: (Left: 10, Width: 224, Height: 40);
          LayoutMode: Top;
          Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmPointsBadge.png", Border: 18);

          Group #PointsLane {
            Anchor: (Top: 8, Width: 182, Height: 20);
            LayoutMode: Top;

            Group #PointsTextBand {
              Anchor: (Top: 1, Width: 170, Height: 18);
              LayoutMode: Center;

              Label #PointsLabel {
                Anchor: (Width: 170, Height: 18);
                Style: (FontSize: 17, Alignment: Center);
                Text: "Points: 0";
              }
            }
          }
        }
        }

        Group #HeaderPlaque {
          Anchor: (Top: 16, Width: 680, Height: 60);
          LayoutMode: Top;
          Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmTitlePlaque.png", Border: 18);

          Group #TitleLane {
            Anchor: (Top: 5, Width: 560, Height: 36);
            LayoutMode: Top;

            Group #TitleTextBand {
              Anchor: (Top: 2, Width: 540, Height: 32);
              LayoutMode: Center;

              Label #TitleLabel {
                Anchor: (Width: 540, Height: 32);
                Style: (FontSize: 30, Alignment: Center);
                Text: "Match Details";
              }
            }
          }
        }

        Group #SubtitleRow {
          Anchor: (Top: 12, Width: 676, Height: 22);
          LayoutMode: Center;

          Group #SubtitleLane {
            Anchor: (Width: 676, Height: 18);
            LayoutMode: Top;

            Group #SubtitleTextBand {
              Anchor: (Top: 1, Width: 664, Height: 16);
              LayoutMode: Center;

              Label #SubtitleLabel {
                Anchor: (Width: 664, Height: 16);
                Style: (FontSize: 15, Alignment: Center, TextColor: #e0ebf4(0.94));
                Text: "Monitor readiness, set the round length, and repair setup issues quickly.";
              }
            }
          }
        }
      }

      Group #StatusBanner {
        Anchor: (Top: 14, Width: 876, Height: 40);
        LayoutMode: Center;
        Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmStatusRibbon.png", Border: 14);

        Label #StatusLabel {
          Anchor: (Width: 796, Height: 22);
          Style: (FontSize: 15, Alignment: Center);
          Text: "";
        }
      }

      Group #SummaryCard {
        Anchor: (Top: 18, Width: 876, Height: 222);
        LayoutMode: Top;
        Padding: (Horizontal: 20, Vertical: 16);
        Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmCardInfo.png", Border: 18);

        Group #SummaryPlaque {
          Anchor: (Width: 188, Height: 30);
          LayoutMode: Center;
          Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmMiniPlaque.png", Border: 12);

          Label #SummaryTitle {
            Anchor: (Width: 138, Height: 20);
            Style: (FontSize: 16, Alignment: Center);
            Text: "Snapshot";
          }
        }

        Group #SummaryRow1 {
          Anchor: (Top: 12, Width: 836, Height: 40);
          LayoutMode: Left;
          Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmRow.png", Border: 8);

          Label #CurrentTeamLabel {
            Anchor: (Width: 164, Height: 40);
            Style: (FontSize: 16, Alignment: Start);
            Text: "Current Team";
          }

          Label #CurrentTeamValue {
            Anchor: (Left: 10, Width: 188, Height: 40);
            Style: (FontSize: 16, Alignment: Start);
            Text: "None";
          }

          Label #MatchStateLabel {
            Anchor: (Left: 16, Width: 126, Height: 40);
            Style: (FontSize: 16, Alignment: Start);
            Text: "Match State";
          }

          Label #MatchStateValue {
            Anchor: (Left: 10, Width: 188, Height: 40);
            Style: (FontSize: 16, Alignment: Start);
            Text: "Lobby Open";
          }
        }

        Group #SummaryRow2 {
          Anchor: (Top: 8, Width: 836, Height: 40);
          LayoutMode: Left;
          Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmRow.png", Border: 8);

          Label #TimerLabel {
            Anchor: (Width: 164, Height: 40);
            Style: (FontSize: 16, Alignment: Start);
            Text: "Timer";
          }

          Label #TimerValue {
            Anchor: (Left: 10, Width: 188, Height: 40);
            Style: (FontSize: 16, Alignment: Start);
            Text: "--:--";
          }

          Label #WaitingLabel {
            Anchor: (Left: 16, Width: 126, Height: 40);
            Style: (FontSize: 16, Alignment: Start);
            Text: "Waiting";
          }

          Label #WaitingValue {
            Anchor: (Left: 10, Width: 188, Height: 40);
            Style: (FontSize: 16, Alignment: Start);
            Text: "0";
          }
        }

        Group #SummaryRow3 {
          Anchor: (Top: 8, Width: 836, Height: 40);
          LayoutMode: Left;
          Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmRow.png", Border: 8);

          Label #LobbyCountsLabel {
            Anchor: (Width: 164, Height: 40);
            Style: (FontSize: 16, Alignment: Start);
            Text: "Lobby Teams";
          }

          Label #LobbyCountsValue {
            Anchor: (Left: 10, Width: 638, Height: 40);
            Style: (FontSize: 16, Alignment: Start);
            Text: "Red:0 Blue:0 Yellow:0 White:0";
          }
        }

        Group #SummaryRow4 {
          Anchor: (Top: 8, Width: 836, Height: 40);
          LayoutMode: Left;
          Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmRow.png", Border: 8);

          Label #ActiveCountsLabel {
            Anchor: (Width: 164, Height: 40);
            Style: (FontSize: 16, Alignment: Start);
            Text: "Active Teams";
          }

          Label #ActiveCountsValue {
            Anchor: (Left: 10, Width: 638, Height: 40);
            Style: (FontSize: 16, Alignment: Start);
            Text: "Red:0 Blue:0 Yellow:0 White:0";
          }
        }
      }

      Group #ControlCard {
        Anchor: (Top: 20, Width: 876, Height: 300);
        LayoutMode: Top;
        Padding: (Horizontal: 18, Vertical: 18);
        Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmCardAction.png", Border: 18);

        Group #ControlPlaque {
          Anchor: (Width: 198, Height: 30);
          LayoutMode: Center;
          Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmMiniPlaque.png", Border: 12);

          Label #ControlTitle {
            Anchor: (Width: 140, Height: 20);
            Style: (FontSize: 16, Alignment: Center);
            Text: "Match Timer";
          }
        }

        Label #ControlText {
          Anchor: (Top: 14, Width: 640, Height: 20);
          Style: (FontSize: 15, Alignment: Center, TextColor: #dce7f0(0.9));
          Text: "Set the round length, then start or stop the shared timer.";
        }

        Group #ControlHero {
          Anchor: (Top: 24, Width: 640, Height: 128);
          LayoutMode: Left;

          Group #MinutesMinusAction {
            Anchor: (Width: 154, Height: 104);
            LayoutMode: Center;

            TextButton #MinutesMinusButton {
              Anchor: (Width: 154, Height: 104);
              Padding: (Horizontal: 12, Bottom: 3);
              Text: "-";
              Style: @RealmMatchStepperButtonStyle;
            }
          }

          Group #TimerMedallion {
            Anchor: (Left: 24, Width: 284, Height: 128);
            LayoutMode: Top;
            Padding: (Horizontal: 22, Vertical: 18);
            Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmTimerMedallion.png", Border: 28);

            Label #MinutesValue {
              Anchor: (Width: 232, Height: 48);
              Style: (FontSize: 38, Alignment: Center);
              Text: "8";
            }

            Label #MinutesLabel {
              Anchor: (Top: 4, Width: 206, Height: 22);
              Style: (FontSize: 14, Alignment: Center, TextColor: #d8e3ed(0.88));
              Text: "Minutes";
            }
          }

          Group #MinutesPlusAction {
            Anchor: (Left: 24, Width: 154, Height: 104);
            LayoutMode: Center;

            TextButton #MinutesPlusButton {
              Anchor: (Width: 154, Height: 104);
              Padding: (Horizontal: 12, Bottom: 3);
              Text: "+";
              Style: @RealmMatchStepperButtonStyle;
            }
          }
        }

        Group #ActionButtonsRow {
          Anchor: (Top: 28, Width: 560, Height: 56);
          LayoutMode: Left;

          Group #StartAction {
            Anchor: (Width: 270, Height: 56);
            LayoutMode: Center;

            TextButton #StartButton {
              Anchor: (Width: 270, Height: 56);
              Padding: (Horizontal: 20, Bottom: 1);
              Text: "Start Match";
              Style: @RealmMatchGoldButtonStyle;
            }
          }

          Group #StopAction {
            Anchor: (Left: 20, Width: 270, Height: 56);
            LayoutMode: Center;

            TextButton #StopButton {
              Anchor: (Width: 270, Height: 56);
              Padding: (Horizontal: 20, Bottom: 1);
              Text: "Stop Match";
              Style: @RealmMatchDangerButtonStyle;
            }
          }
        }
      }

      Group #RegionShortcutCard {
        Anchor: (Top: 12, Width: 876, Height: 72);
        LayoutMode: Left;
        Padding: (Horizontal: 18, Vertical: 14);
        Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmWarningRibbon.png", Border: 16);

        Label #RegionShortcutText {
          Anchor: (Width: 624, Height: 20);
          Style: (FontSize: 14, Alignment: Start);
          Text: "Setup issue detected. Open region tools to repair the arena footprint.";
        }

        Group #RegionShortcutAction {
          Anchor: (Left: 18, Width: 206, Height: 40);
          LayoutMode: Center;

          TextButton #RegionShortcutButton {
            Anchor: (Width: 206, Height: 40);
              Padding: (Horizontal: 18, Bottom: 1);
              Text: "Open Region Tools";
              Style: @RealmMatchDangerButtonStyle;
          }
        }
      }

      Group #StandsShortcutCard {
        Anchor: (Top: 12, Width: 876, Height: 72);
        LayoutMode: Left;
        Padding: (Horizontal: 18, Vertical: 14);
        Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmWarningRibbon.png", Border: 16);

        Label #StandsShortcutText {
          Anchor: (Width: 624, Height: 20);
          Style: (FontSize: 14, Alignment: Start);
          Text: "Stand validation failed. Open the stand registry to restore team spawn locations.";
        }

        Group #StandsShortcutAction {
          Anchor: (Left: 18, Width: 206, Height: 40);
          LayoutMode: Center;

          TextButton #StandsShortcutButton {
            Anchor: (Width: 206, Height: 40);
            Padding: (Horizontal: 18, Bottom: 1);
            Text: "Open Stand Tools";
            Style: @RealmMatchDangerButtonStyle;
          }
        }
      }

      Group #PageFooter {
        Anchor: (Top: 20, Width: 876, Height: 36);
        LayoutMode: Center;
        Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmFooterBar.png", Border: 12);

        Label #CloseHint {
          Anchor: (Width: 190, Height: 20);
          Style: (FontSize: 13, Alignment: Center, TextColor: #cfd9e2(0.88));
          Text: "Press Esc to close";
        }
      }
    }
  }
}
