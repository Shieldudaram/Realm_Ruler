@RealmShopButtonLabelStyle = LabelStyle(
  FontSize: 15,
  TextColor: #dbe7f0,
  RenderBold: true,
  HorizontalAlignment: Center,
  VerticalAlignment: Center,
  ShrinkTextToFit: true,
  MinShrinkTextToFitFontSize: 11,
  LetterSpacing: 1
);

@RealmShopButtonHoveredLabelStyle = LabelStyle(
  ...@RealmShopButtonLabelStyle,
  TextColor: #f3fbff
);

@RealmShopButtonPressedLabelStyle = LabelStyle(
  ...@RealmShopButtonLabelStyle,
  TextColor: #c9d5de
);

@RealmShopButtonDisabledLabelStyle = LabelStyle(
  ...@RealmShopButtonLabelStyle,
  TextColor: #9ea9b3
);

@RealmShopHomeButtonLabelStyle = LabelStyle(
  ...@RealmShopButtonLabelStyle,
  FontSize: 14,
  MinShrinkTextToFitFontSize: 10
);

@RealmShopHomeButtonHoveredLabelStyle = LabelStyle(
  ...@RealmShopHomeButtonLabelStyle,
  TextColor: #f3fbff
);

@RealmShopHomeButtonPressedLabelStyle = LabelStyle(
  ...@RealmShopHomeButtonLabelStyle,
  TextColor: #c9d5de
);

@RealmShopHomeButtonDisabledLabelStyle = LabelStyle(
  ...@RealmShopHomeButtonLabelStyle,
  TextColor: #9ea9b3
);

@RealmShopCompactButtonLabelStyle = LabelStyle(
  FontSize: 12,
  TextColor: #dbe7f0,
  RenderBold: true,
  HorizontalAlignment: Center,
  VerticalAlignment: Center,
  ShrinkTextToFit: true,
  MinShrinkTextToFitFontSize: 9,
  LetterSpacing: 0
);

@RealmShopCompactButtonHoveredLabelStyle = LabelStyle(
  ...@RealmShopCompactButtonLabelStyle,
  TextColor: #f3fbff
);

@RealmShopCompactButtonPressedLabelStyle = LabelStyle(
  ...@RealmShopCompactButtonLabelStyle,
  TextColor: #c9d5de
);

@RealmShopCompactButtonDisabledLabelStyle = LabelStyle(
  ...@RealmShopCompactButtonLabelStyle,
  TextColor: #9ea9b3
);

@RealmShopHomeButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle.png", Border: 12), LabelStyle: @RealmShopHomeButtonLabelStyle),
  Hovered: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle_Hovered.png", Border: 12), LabelStyle: @RealmShopHomeButtonHoveredLabelStyle),
  Pressed: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle_Pressed.png", Border: 12), LabelStyle: @RealmShopHomeButtonPressedLabelStyle),
  Disabled: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle.png", Border: 12, Color: #ffffff(0.58)), LabelStyle: @RealmShopHomeButtonDisabledLabelStyle)
);

@RealmShopCompactSubtleButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle.png", Border: 12), LabelStyle: @RealmShopCompactButtonLabelStyle),
  Hovered: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle_Hovered.png", Border: 12), LabelStyle: @RealmShopCompactButtonHoveredLabelStyle),
  Pressed: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle_Pressed.png", Border: 12), LabelStyle: @RealmShopCompactButtonPressedLabelStyle),
  Disabled: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButtonSubtle.png", Border: 12, Color: #ffffff(0.58)), LabelStyle: @RealmShopCompactButtonDisabledLabelStyle)
);

@RealmShopCompactGoldButtonStyle = TextButtonStyle(
  Default: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButton.png", Border: 12), LabelStyle: @RealmShopCompactButtonLabelStyle),
  Hovered: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButton_Hovered.png", Border: 12), LabelStyle: @RealmShopCompactButtonHoveredLabelStyle),
  Pressed: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButton_Pressed.png", Border: 12), LabelStyle: @RealmShopCompactButtonPressedLabelStyle),
  Disabled: (Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmButton.png", Border: 12, Color: #ffffff(0.58)), LabelStyle: @RealmShopCompactButtonDisabledLabelStyle)
);

Group #RealmRulerCtfShopPage {
  Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
  LayoutMode: Center;

  Group #Backdrop {
    Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
    Background: #02050b(0.74);
  }

  Group #ShopWindow {
    Anchor: (Width: 1092, Height: 844);
    LayoutMode: Center;
    Padding: (Horizontal: 14, Vertical: 14);
    Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmFrame.png", Border: 24);

    Group #ShopPanel {
      Anchor: (Width: 1064, Height: 816);
      LayoutMode: Top;
      Padding: (Horizontal: 20, Vertical: 20);
      Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmInset.png", Border: 18);

      Group #TitleBand {
        Anchor: (Width: 1024, Height: 180);
        LayoutMode: Top;
        Padding: (Horizontal: 18, Vertical: 14);
        Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmInset.png", Border: 16);

        Group #HeaderTopRow {
          Anchor: (Width: 988, Height: 40);
          LayoutMode: Left;

          Group #HomeAction {
            Anchor: (Width: 138, Height: 34);
            LayoutMode: Center;

            TextButton #HomeButton {
              Anchor: (Width: 138, Height: 34);
              Padding: (Horizontal: 16, Bottom: 1);
              Text: "Home";
              Style: @RealmShopHomeButtonStyle;
            }
          }

          Group #HeaderTopSpacer {
            Anchor: (Left: 10, Width: 840, Height: 40);
          }
        }

        Group #HeaderPlaque {
          Anchor: (Top: 12, Width: 760, Height: 60);
          LayoutMode: Top;
          Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmTitlePlaque.png", Border: 18);

          Group #TitleLane {
            Anchor: (Top: 5, Width: 620, Height: 36);
            LayoutMode: Top;

            Group #TitleTextBand {
              Anchor: (Top: 2, Width: 600, Height: 32);
              LayoutMode: Center;

              Label #TitleLabel {
                Anchor: (Width: 600, Height: 32);
                Style: (FontSize: 30, Alignment: Center, RenderBold: true, TextColor: #f7f1e3, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 24);
                Text: "Shop";
              }
            }
          }
        }

        Group #PointsBadgeRow {
          Anchor: (Top: 4, Width: 760, Height: 24);
          LayoutMode: Center;

          Label #PointsLabel {
            Anchor: (Width: 244, Height: 24);
            Style: (FontSize: 20, Alignment: Center, RenderBold: true, TextColor: #cfba82, LetterSpacing: 0);
            Text: "Points: 0";
          }
        }

        Group #SubtitleRow {
          Anchor: (Top: 8, Width: 720, Height: 22);
          LayoutMode: Center;

          Group #SubtitleLane {
            Anchor: (Width: 720, Height: 18);
            LayoutMode: Top;

            Group #SubtitleTextBand {
              Anchor: (Top: 1, Width: 708, Height: 16);
              LayoutMode: Center;

              Label #SubtitleLabel {
                Anchor: (Width: 708, Height: 16);
                Style: (FontSize: 15, Alignment: Center, TextColor: #e0ebf4(0.94), ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 13);
                Text: "Compare costs quickly and buy from the live two-column catalog.";
              }
            }
          }
        }
      }

      Group #StatusBanner {
        Anchor: (Top: 14, Width: 1024, Height: 40);
        LayoutMode: Center;
        Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmStatusRibbon.png", Border: 14);

        Label #StatusLabel {
          Anchor: (Width: 896, Height: 20);
          Style: (FontSize: 15, Alignment: Center);
          Text: "";
        }
      }

      Group #BodyRow {
        Anchor: (Top: 18, Width: 1024, Height: 546);
        LayoutMode: Left;

        Group #CatalogCard {
          Anchor: (Width: 726, Height: 546);
          LayoutMode: Top;
          Padding: (Horizontal: 20, Vertical: 18);
          Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmCardInfo.png", Border: 18);

          Group #CatalogPlaque {
            Anchor: (Width: 192, Height: 34);
            LayoutMode: Center;
            Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmMiniPlaque.png", Border: 12);

            Label #CatalogTitle {
              Anchor: (Width: 120, Height: 22);
              Style: (FontSize: 16, Alignment: Center);
              Text: "Catalog";
            }
          }

          Label #CatalogSubtitle {
            Anchor: (Top: 12, Width: 620, Height: 20);
            Style: (FontSize: 15, Alignment: Center, TextColor: #dce7f0(0.9));
            Text: "Browse dense rows with clearer costs and cleaner actions.";
          }

          Group #CatalogGrid {
            Anchor: (Top: 18, Width: 686, Height: 420);
            LayoutMode: Left;

            Group #CatalogLeftColumn {
              Anchor: (Width: 336, Height: 420);
              LayoutMode: Top;

              Group #Entry0 {
                Anchor: (Width: 336, Height: 48);
                LayoutMode: Left;
                Padding: (Horizontal: 8, Vertical: 8);
                Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmRow.png", Border: 8);

                Group #Entry0SelectedAccent {
                  Anchor: (Width: 12, Height: 40);
                  Background: #4fc5ff(0.98);
                }

                Label #Entry0Name {
                  Anchor: (Left: 10, Width: 132, Height: 32);
                  Style: (FontSize: 14, Alignment: Start);
                  Text: "Item Name";
                }

                Group #Entry0CostBadge {
                  Anchor: (Left: 6, Width: 50, Height: 40);
                  LayoutMode: Center;
                  Background: (TexturePath: "../../Hud/RealmRulerTheme/RealmPointsBadge.png", Border: 14);

                  Label #Entry0Cost {
                    Anchor: (Width: 36, Height: 22);
                    Style: (FontSize: 15, Alignment: Center);
                    Text: "0";
                  }
                }

                Group #Entry0ViewAction {
                  Anchor: (Left: 8, Width: 56, Height: 40);
                  LayoutMode: Center;

                  TextButton #Entry0ViewButton {
                    Anchor: (Width: 56, Height: 40);
                    Padding: (Horizontal: 8, Bottom: 1);
                    Text: "View";
                    Style: @RealmShopCompactSubtleButtonStyle;
                  }
                }

                Group #Entry0BuyAction {
                  Anchor: (Left: 8, Width: 56, Height: 40);
                  LayoutMode: Center;

                  TextButton #Entry0BuyButton {
                    Anchor: (Width: 56, Height: 40);
                    Padding: (Horizontal: 8, Bottom: 1);
                    Text: "Buy";
                    Style: @RealmShopCompactGoldButtonStyle;
                  }
